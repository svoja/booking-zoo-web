# Copy this file to `.env` before running production compose.

# Required secrets
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_PASSWORD=change_this_app_password

# Optional overrides
MYSQL_DATABASE=zoo_booking
MYSQL_USER=zoo_user

# Frontend/public URL used when generating share links.
# Example: https://booking.yourdomain.com
VITE_PUBLIC_BASE_URL=

# Comma-separated allowed CORS origins for cross-origin API calls.
# Leave empty when frontend and API are served from the same origin.
# Example: https://booking.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=
